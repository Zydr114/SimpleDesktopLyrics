<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasyDesktopLyrics.ViewModels"
        x:Class="EasyDesktopLyrics.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="EasyDesktopLyrics 设置"
        Width="640" Height="680" MinWidth="540" MinHeight="560"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.ColorBtn">
      <Setter Property="Width" Value="26" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Margin" Value="2" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
  </Window.Styles>

  <TabControl Margin="8">
    <!-- 外观 -->
    <TabItem Header="外观">
      <ScrollViewer Padding="12,8">
        <StackPanel Spacing="8" MaxWidth="520">
          <!-- 字体 -->
          <StackPanel Spacing="4">
            <TextBlock Text="字体" FontWeight="Medium" />
            <ComboBox ItemsSource="{Binding FontOptions}"
                      SelectedItem="{Binding SelectedFont, Mode=TwoWay}" />
            <Border Padding="8,4" Margin="0,2" Background="{DynamicResource SystemAltLowColor}"
                    CornerRadius="4">
              <TextBlock Text="{Binding FontPreviewText}"
                         FontFamily="{Binding SelectedFontFamily}"
                         FontSize="16" />
            </Border>
          </StackPanel>

          <!-- 字号 & 字重 -->
          <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <StackPanel Spacing="4" Grid.Column="0">
              <TextBlock Text="正文字号" FontWeight="Medium" />
              <TextBox Text="{Binding FontSize, Mode=TwoWay}" HorizontalContentAlignment="Right" />
            </StackPanel>
            <StackPanel Spacing="4" Grid.Column="1">
              <TextBlock Text="字重" FontWeight="Medium" />
              <ComboBox ItemsSource="{Binding WeightOptions}"
                        SelectedIndex="{Binding WeightIndex, Mode=TwoWay}" />
            </StackPanel>
          </Grid>

          <!-- 翻译字号 & 行间距 -->
          <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <StackPanel Spacing="4" Grid.Column="0">
              <TextBlock Text="翻译字号（0=自动）" FontWeight="Medium" />
              <TextBox Text="{Binding TransFontSizeVal, Mode=TwoWay}" HorizontalContentAlignment="Right" />
            </StackPanel>
            <StackPanel Spacing="4" Grid.Column="1">
              <TextBlock Text="行间距（DIP）" FontWeight="Medium" />
              <TextBox Text="{Binding LineSpacingVal, Mode=TwoWay}" HorizontalContentAlignment="Right" />
            </StackPanel>
          </Grid>

          <!-- 文字颜色 -->
          <StackPanel Spacing="4">
            <TextBlock Text="文字颜色" FontWeight="Medium" />
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
              <Border x:Name="MainColorPreview" Grid.Column="0" Width="40" Height="40"
                      CornerRadius="4" VerticalAlignment="Center" />
              <TextBox Grid.Column="1" Text="{Binding ColorHex, Mode=TwoWay}" VerticalAlignment="Center" />
              <WrapPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" MaxWidth="120">
                <Button Classes="ColorBtn" Background="#FFFFFF" Command="{Binding PickColorCommand}" CommandParameter="#FFFFFF" />
                <Button Classes="ColorBtn" Background="#FFD700" Command="{Binding PickColorCommand}" CommandParameter="#FFD700" />
                <Button Classes="ColorBtn" Background="#00FF88" Command="{Binding PickColorCommand}" CommandParameter="#00FF88" />
                <Button Classes="ColorBtn" Background="#00BFFF" Command="{Binding PickColorCommand}" CommandParameter="#00BFFF" />
                <Button Classes="ColorBtn" Background="#FF6B6B" Command="{Binding PickColorCommand}" CommandParameter="#FF6B6B" />
                <Button Classes="ColorBtn" Background="#BA55D3" Command="{Binding PickColorCommand}" CommandParameter="#BA55D3" />
              </WrapPanel>
            </Grid>
            <WrapPanel x:Name="MainColorPalette" MaxWidth="500" Margin="0,2,0,0" />
          </StackPanel>

          <!-- 阴影 & 描边 -->
          <CheckBox Content="文字阴影" IsChecked="{Binding ShadowEnabled, Mode=TwoWay}" />
          <StackPanel Spacing="4">
            <CheckBox Content="文字描边" IsChecked="{Binding StrokeEnabled, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8"
                  IsVisible="{Binding StrokeEnabled}" Margin="18,2,0,0">
              <StackPanel Spacing="2" Grid.Column="0">
                <TextBlock Text="描边颜色" FontSize="12" />
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                  <Border x:Name="StrokeColorPreview" Grid.Column="0" Width="30" Height="30"
                          CornerRadius="3" />
                  <TextBox Grid.Column="1" Text="{Binding StrokeColorHex, Mode=TwoWay}" />
                </Grid>
              </StackPanel>
              <StackPanel Spacing="2" Grid.Column="1">
                <TextBlock Text="描边宽度" FontSize="12" />
                <Slider Minimum="1" Maximum="8" TickFrequency="0.5" Value="{Binding StrokeThicknessVal, Mode=TwoWay}" />
              </StackPanel>
            </Grid>
          </StackPanel>

          <!-- 不透明度 & 最大宽度 -->
          <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
            <StackPanel Spacing="4" Grid.Column="0">
              <TextBlock Text="不透明度" FontWeight="Medium" />
              <Slider Minimum="0.1" Maximum="1.0" TickFrequency="0.05"
                      Value="{Binding TextOpacity, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel Spacing="4" Grid.Column="1">
              <TextBlock Text="最大宽度（DIP）" FontWeight="Medium" />
              <TextBox Text="{Binding MaxWidth, Mode=TwoWay}" HorizontalContentAlignment="Right" />
            </StackPanel>
          </Grid>

          <!-- 位置 -->
          <StackPanel Spacing="6">
            <TextBlock Text="歌词位置" FontWeight="Medium" />
            <ComboBox ItemsSource="{Binding PresetOptionLabels}"
                      SelectedIndex="{Binding SelectedPresetIndex, Mode=TwoWay}" />
            <Grid ColumnDefinitions="30,*,45" ColumnSpacing="6" Margin="2,4,0,0">
              <TextBlock Text="水平" Grid.Column="0" VerticalAlignment="Center" FontSize="12" />
              <Slider Minimum="5" Maximum="95" TickFrequency="1" Grid.Column="1"
                      Value="{Binding PositionXPct, Mode=TwoWay}" />
              <TextBlock Text="{Binding PositionXPct, StringFormat='{}{0:F0}%'}"
                         Grid.Column="2" VerticalAlignment="Center" FontSize="12" TextAlignment="Right" />
            </Grid>
            <Grid ColumnDefinitions="30,*,45" ColumnSpacing="6" Margin="2,2,0,0">
              <TextBlock Text="垂直" Grid.Column="0" VerticalAlignment="Center" FontSize="12" />
              <Slider Minimum="5" Maximum="95" TickFrequency="1" Grid.Column="1"
                      Value="{Binding PositionYPct, Mode=TwoWay}" />
              <TextBlock Text="{Binding PositionYPct, StringFormat='{}{0:F0}%'}"
                         Grid.Column="2" VerticalAlignment="Center" FontSize="12" TextAlignment="Right" />
            </Grid>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <!-- 行为 -->
    <TabItem Header="行为">
      <StackPanel Spacing="12" Margin="12,10" MaxWidth="500">
        <CheckBox Content="显示翻译行"
                  IsChecked="{Binding ShowTranslation, Mode=TwoWay}" />
        <StackPanel Spacing="4">
          <TextBlock Text="对齐方式" FontWeight="Medium" />
          <ComboBox ItemsSource="{Binding AlignmentOptions}"
                    SelectedIndex="{Binding AlignmentIndex, Mode=TwoWay}" />
        </StackPanel>
        <CheckBox Content="暂停时隐藏歌词"
                  IsChecked="{Binding HideWhenPaused, Mode=TwoWay}" />
        <CheckBox Content="无歌词时显示曲目标题"
                  IsChecked="{Binding ShowTitleWhenNoLyric, Mode=TwoWay}" />
        <CheckBox Content="开机自启"
                  IsChecked="{Binding AutoStartEnabled, Mode=TwoWay}" />
      </StackPanel>
    </TabItem>

    <!-- SMTC 与歌词源 -->
    <TabItem Header="SMTC &amp; 歌词源">
      <ScrollViewer Padding="12,10">
        <StackPanel Spacing="12" MaxWidth="500">
          <StackPanel Spacing="4">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Text="监听播放器" FontWeight="Medium" Grid.Column="0"
                         VerticalAlignment="Center" />
              <Button Content="刷新" Grid.Column="1"
                      Command="{Binding RefreshSessionsCommand}" Padding="12,4" />
            </Grid>
            <ComboBox ItemsSource="{Binding SessionOptions}"
                      SelectedItem="{Binding SelectedSession, Mode=TwoWay}" />
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="歌词源" FontWeight="Medium" />
            <CheckBox Content="网易云音乐" IsChecked="{Binding NeteaseEnabled, Mode=TwoWay}" />
            <CheckBox Content="QQ 音乐" IsChecked="{Binding QQMusicEnabled, Mode=TwoWay}" />
            <CheckBox Content="优先网易云音乐（否则优先 QQ 音乐）"
                      IsChecked="{Binding NeteaseFirst, Mode=TwoWay}" Margin="16,2,0,0" />
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="全局歌词偏移（ms，正值 = 歌词提前）" FontWeight="Medium" />
            <TextBox Text="{Binding GlobalOffsetMs, Mode=TwoWay}"
                     HorizontalContentAlignment="Right" />
          </StackPanel>

          <!-- 手动校正 -->
          <Border CornerRadius="6" Padding="10" Margin="0,6,0,0"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                  BorderThickness="1">
            <StackPanel Spacing="8">
              <TextBlock Text="手动校正当前曲目" FontWeight="Bold" FontSize="14" />
              <TextBlock Text="{Binding CurrentTrackText}" TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <TextBox Text="{Binding SearchKeyword, Mode=TwoWay}" Grid.Column="0" />
                <Button Content="搜索" Grid.Column="1"
                        Command="{Binding SearchCommand}" Padding="14,4" />
              </Grid>
              <ListBox ItemsSource="{Binding SearchResults}"
                       SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                       Height="130" IsVisible="{Binding HasSearchResults}" />
              <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="应用所选歌词" Command="{Binding ApplyResultCommand}" Padding="12,4" />
                <Button Content="清除本曲校正" Command="{Binding ClearOverrideCommand}" Padding="12,4" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="本曲偏移 (ms)" VerticalAlignment="Center" MinWidth="80" />
                <TextBox Text="{Binding SongOffsetMs, Mode=TwoWay}" Width="100"
                         HorizontalContentAlignment="Right" />
                <Button Content="应用偏移" Command="{Binding ApplySongOffsetCommand}" Padding="10,4" />
              </StackPanel>
              <Button Content="清空歌词缓存" Command="{Binding ClearCacheCommand}" Padding="10,4" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>
  </TabControl>

</Window>
